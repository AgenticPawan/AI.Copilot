{
    "servers": {
        // ── Core MCP Servers ─────────────────────────────────────
        "github": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/"
        },
        // ── Custom MCP Servers ───────────────────────────────────
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem"
            ],
            "env": {
                "MCP_FS_ROOT": "E:\\GITHUB\\AI.VirtualStudio"
            }
        },
        "angular-playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-angular-playwright"
            ],
            "env": {
                "PLAYWRIGHT_BROWSER": "chromium"
            }
        },
        "angular-cli": {
            "command": "npx",
            "args": [
                "-y",
                "@angular/cli",
                "mcp"
            ],
            "env": {
                "NG_CLI_PROJECT": "E:\\GITHUB\\AI.VirtualStudio\\src\\frontend"
            }
        },
        "dotnet": {
            "command": "dotnet",
            "args": [
                "run",
                "--project",
                "src/mcp-servers/DotnetMcpServer/DotnetMcpServer.csproj"
            ]
        }
    }
}